PRD Backend

backend-development/ # Root folder untuk seluruh source code backend
├── src/ # Folder utama source code aplikasi backend
│   ├── app.js # Konfigurasi utama Express app, middleware global, routes utama
│   ├── server.js # Entry point untuk menjalankan server/backend
│
│   ├── config/ # Menyimpan konfigurasi global aplikasi backend
│   │   ├── env.js # Membaca dan memvalidasi environment variable dari file .env
│   │   ├── cors.config.js # Konfigurasi CORS agar frontend bisa mengakses backend
│   │   ├── multer.config.js # Konfigurasi upload file menggunakan multer
│   │   └── jwt.config.js # Konfigurasi JWT seperti secret key dan expired time
│
│   ├── database/ # Menyimpan seluruh hal yang berhubungan dengan database
│   │   ├── db.js # Koneksi utama ke database MySQL menggunakan mysql2
│   │   ├── migrations/ # File perubahan struktur tabel database secara bertahap
│   │   └── seeders/ # File data awal/dummy untuk mengisi database
│
│   ├── common/ # Folder untuk kode reusable yang dipakai lintas module/fitur
│   │   ├── constants/ # Menyimpan nilai tetap seperti role, permission, dan status
│   │   │   ├── roles.js # Daftar role sistem seperti MEO, BD, CEO, COO, PM, Consultant, Staff Admin
│   │   │   ├── permissions.js # Daftar permission/action yang boleh dilakukan user
│   │   │   └── statuses.js # Daftar status global seperti draft, pending, approved, rejected
│   │   │
│   │   ├── middlewares/ # Middleware global yang berjalan sebelum controller
│   │   │   ├── auth.middleware.js # Mengecek apakah user sudah login melalui JWT
│   │   │   ├── permission.middleware.js # Mengecek apakah role user boleh mengakses endpoint tertentu
│   │   │   ├── error.middleware.js # Menangani error response agar formatnya konsisten
│   │   │   ├── validate.middleware.js # Menjalankan validasi request body/query/params
│   │   │   └── upload.middleware.js # Middleware upload file untuk proposal, EL, handover, dokumen, dll
│   │   │
│   │   ├── helpers/ # Fungsi bantuan yang berhubungan dengan kebutuhan aplikasi
│   │   │   ├── response.helper.js # Membuat format response API yang konsisten
│   │   │   ├── pagination.helper.js # Membantu membuat limit, offset, page, total data
│   │   │   ├── token.helper.js # Membuat dan membaca JWT token
│   │   │   └── password.helper.js # Hash password dan compare password dengan bcrypt
│   │   │
│   │   └── utils/ # Fungsi utilitas murni yang tidak bergantung ke database
│   │       ├── date.util.js # Format tanggal dan helper waktu
│   │       ├── file.util.js # Helper nama file, path file, dan validasi ekstensi file
│   │       └── currency.util.js # Format angka, rupiah, DPP, PPN, PPh, dan total pembayaran
│
│   ├── modules/ # Folder utama seluruh fitur bisnis backend
│   │   ├── auth/ # Modul autentikasi user
│   │   │   ├── auth.routes.js # Endpoint login, logout, refresh token, current user
│   │   │   ├── auth.controller.js # Mengatur request dan response auth
│   │   │   ├── auth.service.js # Logika login, validasi password, generate token
│   │   │   ├── auth.repository.js # Query database untuk mencari user login
│   │   │   ├── auth.validator.js # Validasi input login
│   │   │   └── auth.dto.js # Format response user login agar aman dikirim ke frontend
│   │   │
│   │   ├── users/ # Modul manajemen user internal
│   │   │   ├── user.routes.js # Endpoint CRUD user
│   │   │   ├── user.controller.js # Mengatur request dan response user
│   │   │   ├── user.service.js # Logika pembuatan user, update role, aktivasi user
│   │   │   ├── user.repository.js # Query database tabel users
│   │   │   ├── user.validator.js # Validasi input user
│   │   │   └── user.dto.js # Format response user tanpa password/hash
│   │   │
│   │   ├── campaigns/ # Modul campaign marketing/business development
│   │   │   ├── campaign.routes.js # Endpoint list, detail, create, update, delete campaign
│   │   │   ├── campaign.controller.js # Mengatur request dan response campaign
│   │   │   ├── campaign.service.js # Logika bisnis campaign, periode campaign, status campaign
│   │   │   ├── campaign.repository.js # Query database campaign
│   │   │   ├── campaign.validator.js # Validasi input campaign
│   │   │   └── campaign.dto.js # Format response campaign untuk frontend
│   │   │
│   │   ├── forms/ # Modul form builder internal
│   │   │   ├── form.routes.js # Endpoint CRUD form dan field form
│   │   │   ├── form.controller.js # Mengatur request dan response form builder
│   │   │   ├── form.service.js # Logika membuat form, field, opsi jawaban, dan generate link
│   │   │   ├── form.repository.js # Query database forms, form_fields, form_options
│   │   │   ├── form.validator.js # Validasi struktur form dan field
│   │   │   └── form.dto.js # Format response form builder
│   │   │
│   │   ├── public-forms/ # Modul form publik yang diisi calon client tanpa login
│   │   │   ├── public-form.routes.js # Endpoint membuka form publik dan submit response
│   │   │   ├── public-form.controller.js # Mengatur request dan response form publik
│   │   │   ├── public-form.service.js # Logika validasi link publik dan penyimpanan response
│   │   │   ├── public-form.repository.js # Query untuk mengambil form publik dan menyimpan submission
│   │   │   └── public-form.validator.js # Validasi jawaban calon client
│   │   │
│   │   ├── bank-data/ # Modul bank data untuk menampung seluruh response lead
│   │   │   ├── bank-data.routes.js # Endpoint list bank data, detail, process, archive
│   │   │   ├── bank-data.controller.js # Mengatur request dan response bank data
│   │   │   ├── bank-data.service.js # Logika process lead ke lead tracker atau archive
│   │   │   ├── bank-data.repository.js # Query database bank data dan submission
│   │   │   ├── bank-data.validator.js # Validasi action process/archive
│   │   │   └── bank-data.dto.js # Format response bank data
│   │   │
│   │   ├── leads/ # Modul lead tracker dan data utama lead
│   │   │   ├── lead.routes.js # Endpoint list lead, detail lead, create manual lead, update stage
│   │   │   ├── lead.controller.js # Mengatur request dan response lead
│   │   │   ├── lead.service.js # Logika pipeline lead, stage progress, next action, status lead
│   │   │   ├── lead.repository.js # Query database leads
│   │   │   ├── lead.validator.js # Validasi input lead
│   │   │   └── lead.dto.js # Format response lead tracker
│   │   │
│   │   ├── meetings/ # Modul jadwal meeting dengan client/prospect
│   │   │   ├── meeting.routes.js # Endpoint CRUD meeting berdasarkan lead
│   │   │   ├── meeting.controller.js # Mengatur request dan response meeting
│   │   │   ├── meeting.service.js # Logika jadwal meeting, reminder, hasil meeting
│   │   │   ├── meeting.repository.js # Query database meetings
│   │   │   ├── meeting.validator.js # Validasi input meeting
│   │   │   └── meeting.dto.js # Format response meeting
│   │   │
│   │   ├── notulensi/ # Modul notulensi hasil meeting
│   │   │   ├── notulensi.routes.js # Endpoint CRUD notulensi berdasarkan lead/meeting
│   │   │   ├── notulensi.controller.js # Mengatur request dan response notulensi
│   │   │   ├── notulensi.service.js # Logika penyusunan catatan meeting dan follow-up
│   │   │   ├── notulensi.repository.js # Query database notulensi
│   │   │   ├── notulensi.validator.js # Validasi input notulensi
│   │   │   └── notulensi.dto.js # Format response notulensi
│   │   │
│   │   ├── proposals/ # Modul proposal penawaran jasa
│   │   │   ├── proposal.routes.js # Endpoint CRUD proposal, submit approval, upload file
│   │   │   ├── proposal.controller.js # Mengatur request dan response proposal
│   │   │   ├── proposal.service.js # Logika fee, termin, pajak, status proposal, submit ke CEO
│   │   │   ├── proposal.repository.js # Query database proposal dan payment terms
│   │   │   ├── proposal.validator.js # Validasi input proposal
│   │   │   └── proposal.dto.js # Format response proposal, termasuk filter data harga sesuai role
│   │   │
│   │   ├── engagement-letters/ # Modul engagement letter setelah proposal disetujui
│   │   │   ├── engagement-letter.routes.js # Endpoint CRUD EL, submit approval, upload file
│   │   │   ├── engagement-letter.controller.js # Mengatur request dan response EL
│   │   │   ├── engagement-letter.service.js # Logika pembuatan EL, status tanda tangan, approval CEO
│   │   │   ├── engagement-letter.repository.js # Query database engagement letters
│   │   │   ├── engagement-letter.validator.js # Validasi input engagement letter
│   │   │   └── engagement-letter.dto.js # Format response engagement letter
│   │   │
│   │   ├── handovers/ # Modul handover memo setelah EL ditandatangani
│   │   │   ├── handover.routes.js # Endpoint CRUD handover, submit, revision, approval
│   │   │   ├── handover.controller.js # Mengatur request dan response handover
│   │   │   ├── handover.service.js # Logika status handover dari draft sampai approved
│   │   │   ├── handover.repository.js # Query database handover dan detail handover
│   │   │   ├── handover.validator.js # Validasi input handover
│   │   │   └── handover.dto.js # Format response handover, termasuk masking data sensitif
│   │   │
│   │   ├── approvals/ # Modul approval center untuk CEO/COO
│   │   │   ├── approval.routes.js # Endpoint list approval, approve, reject/request revision
│   │   │   ├── approval.controller.js # Mengatur request dan response approval
│   │   │   ├── approval.service.js # Logika approval proposal, EL, handover
│   │   │   ├── approval.repository.js # Query data approval dari berbagai dokumen
│   │   │   ├── approval.validator.js # Validasi action approve/revision
│   │   │   └── approval.dto.js # Format response approval inbox
│   │   │
│   │   ├── projects/ # Modul project setelah handover disetujui dan PM ditugaskan
│   │   │   ├── project.routes.js # Endpoint project pipeline, detail, assign PM, assign consultant
│   │   │   ├── project.controller.js # Mengatur request dan response project
│   │   │   ├── project.service.js # Logika spawn project dari handover, assign PM, assign consultant, update milestone
│   │   │   ├── project.repository.js # Query database projects, project_team, milestones
│   │   │   ├── project.validator.js # Validasi input project dan milestone
│   │   │   └── project.dto.js # Format response project sesuai role, terutama financials
│   │   │
│   │   ├── documents/ # Modul document center dan file management
│   │   │   ├── document.routes.js # Endpoint upload, list, detail, download, delete document
│   │   │   ├── document.controller.js # Mengatur request dan response dokumen
│   │   │   ├── document.service.js # Logika upload dokumen, metadata, akses dokumen
│   │   │   ├── document.repository.js # Query database dokumen
│   │   │   ├── document.validator.js # Validasi file dan metadata dokumen
│   │   │   └── document.dto.js # Format response dokumen
│   │   │
│   │   └── invoices/ # Modul invoice dan termin pembayaran
│   │       ├── invoice.routes.js # Endpoint invoice, termin, status pembayaran, approval invoice
│   │       ├── invoice.controller.js # Mengatur request dan response invoice
│   │       ├── invoice.service.js # Logika DPP, PPN, PPh 23, total invoice, status pembayaran
│   │       ├── invoice.repository.js # Query database invoice dan invoice terms
│   │       ├── invoice.validator.js # Validasi input invoice
│   │       └── invoice.dto.js # Format response invoice
│   │
│   └── routes/ # Folder untuk menggabungkan seluruh routes dari modules
│       └── index.js # Register semua module route ke prefix /api
│
├── uploads/ # Folder penyimpanan file yang diupload user
│   ├── profile-images/ # Menyimpan foto profil user
│   ├── form-headers/ # Menyimpan gambar/header untuk public form
│   ├── form-attachments/ # Menyimpan file yang diupload calon client lewat form
│   ├── proposal-files/ # Menyimpan file proposal
│   ├── engagement-letter-files/ # Menyimpan file engagement letter
│   ├── handover-files/ # Menyimpan file pendukung handover
│   └── project-documents/ # Menyimpan dokumen project dan deliverable
│
├── tests/ # Folder testing backend
│   ├── auth.test.js # Testing fitur auth
│   ├── campaign.test.js # Testing fitur campaign
│   └── lead.test.js # Testing fitur lead
│
├── .env # File konfigurasi rahasia lokal seperti DB password dan JWT secret
├── .env.example # Contoh format .env tanpa data rahasia
├── .gitignore # Daftar file/folder yang tidak dimasukkan ke Git
├── package.json # Dependency, script, dan metadata project backend
└── README.md # Dokumentasi cara menjalankan backend