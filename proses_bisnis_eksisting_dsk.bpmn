  <collaboration id="Collaboration_DSK">
    <participant id="Pool_DSK" name="PT DSK Global Konsultama" processRef="Process_DSK" />
  </collaboration>
  <process id="Process_DSK" isExecutable="false">
    <laneSet id="LaneSet_1">
      <lane id="Lane_CEO" name="CEO">
        <flowNodeRef>StartEvent_1</flowNodeRef>
        <flowNodeRef>Task_AkuisisiClient</flowNodeRef>
        <flowNodeRef>Task_HandoverPM</flowNodeRef>
        <flowNodeRef>Task_EvaluasiCEO</flowNodeRef>
        <flowNodeRef>Task_TerimaLaporan</flowNodeRef>
        <flowNodeRef>EndEvent_1</flowNodeRef>
      </lane>
      <lane id="Lane_PM" name="Project Manager">
        <flowNodeRef>Task_Scoping</flowNodeRef>
        <flowNodeRef>Task_Penugasan</flowNodeRef>
        <flowNodeRef>Task_MonitoringManual</flowNodeRef>
        <flowNodeRef>Task_RekapManual</flowNodeRef>
        <flowNodeRef>Task_Delivery</flowNodeRef>
      </lane>
      <lane id="Lane_Konsultan" name="Konsultan">
        <flowNodeRef>Task_EksekusiPekerjaan</flowNodeRef>
        <flowNodeRef>Task_UpdateInformal</flowNodeRef>
      </lane>
    </laneSet>
    <sequenceFlow id="Flow_6" sourceRef="Task_EksekusiPekerjaan" targetRef="Task_UpdateInformal" />
