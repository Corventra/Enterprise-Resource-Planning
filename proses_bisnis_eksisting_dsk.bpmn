    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_AkuisisiClient" />
    <task id="Task_UpdateInformal" name="Update Progres&#10;Informal via WA" />
    <task id="Task_EksekusiPekerjaan" name="Eksekusi Pekerjaan&#10;TP-Doc">
      <incoming>Flow_4</incoming>
    </task>
    <endEvent id="EndEvent_1" name="END" />
    <task id="Task_TerimaLaporan" name="Terima Laporan&#10;Progres dari PM" />
    <task id="Task_EvaluasiCEO" name="Evaluasi Subjektif&#10;(Tanpa KPI Standar)" />
    <task id="Task_Delivery" name="Delivery&#10;ke Klien" />
    <task id="Task_RekapManual" name="Rekap Manual&#10;Progres ke Direksi">
      <incoming>Flow_0kxu7x7</incoming>
    </task>
    <task id="Task_MonitoringManual" name="Monitoring Manual&#10;(Excel + WA + Email)">
      <outgoing>Flow_0kxu7x7</outgoing>
    </task>
    <task id="Task_Penugasan" name="Penugasan&#10;ke Konsultan">
      <incoming>Flow_1oo30wt</incoming>
      <outgoing>Flow_4</outgoing>
    </task>
    <task id="Task_Scoping" name="Scoping&#10;Pekerjaan TP-Doc">
      <outgoing>Flow_1oo30wt</outgoing>
    </task>
    <task id="Task_HandoverPM" name="Handover Proyek&#10;ke PM (Informal)">
      <outgoing>Flow_3</outgoing>
    </task>
    <task id="Task_AkuisisiClient" name="Mendapat&#10;Client Baru" />
    <startEvent id="StartEvent_1" name="START" />
  </process>
