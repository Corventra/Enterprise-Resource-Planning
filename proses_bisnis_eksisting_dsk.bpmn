    <sequenceFlow id="Flow_1oo30wt" sourceRef="Task_Scoping" targetRef="Task_Penugasan" />
    <sequenceFlow id="Flow_3" sourceRef="Task_HandoverPM" targetRef="Task_Scoping" />
